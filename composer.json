{
    "name": "hakimace/filament-api-login",
    "description": "Token-based authentication for FilamentPHP that authenticates against external APIs without requiring local database users",
    "type": "library",
    "keywords": ["laravel", "filament", "authentication", "external-api", "token-auth", "filamentphp"],
    "license": "MIT",
    "authors": [
        {
            "name": "Hakimace",
            "email": "hakim75@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0|^11.0|^12.0",
        "filament/filament": "^3.0|^4.0|^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Hakimace\\FilamentApiLogin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hakimace\\FilamentApiLogin\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hakimace\\FilamentApiLogin\\FilamentApiLoginServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
